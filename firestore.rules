rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true) ||
         ("email" in request.auth.token && request.auth.token.email == "vedantpalandurkar14@gmail.com"));
    }

    function isValidMovie(data) {
      return data.keys().hasAll(['title', 'genre', 'rating', 'status', 'addedBy', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.genre is string && data.genre.size() > 0 && data.genre.size() < 50 &&
             data.rating is number && data.rating >= 0 && data.rating <= 10 &&
             data.status in ["Watched", "To Watch", "Watching", "Wishlist"] &&
             data.addedBy is string &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'isAdmin']) &&
             data.firstName is string && data.firstName.size() > 0 && data.firstName.size() < 50 &&
             data.lastName is string && data.lastName.size() >= 0 && data.lastName.size() < 50 &&
             data.isAdmin is bool;
    }

    // Movies Collection
    match /movies/{movieId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.addedBy == request.auth.uid;
      allow update: if request.auth != null && (request.resource.data.addedBy == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }
  }
}
